<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <TextView
        android:id="@+id/robot_block_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/robot_block_title_height"
        android:gravity="center_vertical|left"
        android:paddingLeft="@dimen/robot_camera_margin_right"
        android:textSize="@dimen/robot_block_title_font_size"
        android:background="@color/title_bar_background"
        android:textColor="@android:color/white"
        android:text="@string/app_name" />


    <RelativeLayout
        android:id="@+id/robot_block"
        android:layout_below="@id/robot_block_title"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/robot_asleep_background"
        android:clipChildren="false">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:padding="5dp">

            <com.emotibot.common.widget.RobotEyeView
                xmlns:custom="http://schemas.android.com/apk/res-auto"
                android:id="@+id/camera_impl"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:scaleType="fitCenter"
                android:background="@android:color/transparent"
                custom:maxCameraWidth="@integer/max_camera_width"
                custom:maxCameraHeight="@integer/max_camera_height"
                custom:minCameraWidth="@integer/min_camera_width"
                custom:minCameraHeight="@integer/min_camera_height"
                />
            <com.opencv.common.widget.DecorationView
                android:id="@+id/decorate_view_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:scaleType="fitCenter"
                android:background="@android:color/transparent"/>

            <ImageView
                android:id="@+id/robot_animation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="fitCenter"
                android:src="@drawable/emoji_neutral_01_normal_000"
                android:visibility="invisible"/>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentLeft="true"
                android:layout_marginBottom="@dimen/camera_btn_container_margin_bottom_right"
                android:paddingLeft="@dimen/attribute_margin_left">
                <!-- Attribute block -->
                <include
                    layout="@layout/attribute_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />
                <!-- Attribute block -->
            </RelativeLayout>
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignParentRight="true"
                android:layout_marginBottom="@dimen/camera_btn_container_margin_bottom_right"
                android:layout_marginRight="@dimen/camera_btn_container_margin_bottom_right"
                android:paddingRight="@dimen/robot_camera_margin_right">
                <ImageView
                    android:id="@+id/camera_showhide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="fitCenter"
                    android:layout_toRightOf="@+id/camera_switcher"
                    android:src="@drawable/ic_camera_off"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="@dimen/camera_btn_container_margin_bottom_right"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/camera_switcher"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_rotate_camera"
                    android:background="@color/btn_background" />

            </RelativeLayout>

        </RelativeLayout>

    </RelativeLayout>




</RelativeLayout>